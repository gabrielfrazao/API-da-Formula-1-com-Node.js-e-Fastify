# Configurações de Produção
# NÃO envie as credenciais reais para o repositório!
# Use variáveis de ambiente ou secrets gerenciados

# Servidor
PORT=3000
NODE_ENV=production
LOG_LEVEL=warn

# CORS - Restringir a apenas domínios conhecidos
CORS_ORIGIN=https://seu-dominio.com
CORS_CREDENTIALS=true

# Rate Limiting - Mais restritivo em produção
RATE_LIMIT=50
